# Copy this file to:
#   docs/ops/examples/.env
# and fill in your real credentials locally.
#
# Do NOT commit real credentials.

# CQG
CQG_TEST_KEY=your_cqg_key_id
CQG_TEST_SECRET=your_cqg_secret

# Rithmic
RITHMIC_TEST_KEY=your_rithmic_user_or_key
RITHMIC_TEST_SECRET=your_rithmic_password_or_secret

# Optional live variable names if your config uses different env refs
# CQG_LIVE_KEY=
# CQG_LIVE_SECRET=
# RITHMIC_LIVE_KEY=
# RITHMIC_LIVE_SECRET=
